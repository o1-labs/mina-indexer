# Arguments passed to `mina-indexer server start` by the systemd service.
#
# Default targets mainnet (its genesis ledger is embedded in the binary); you
# only need to supply a blocks directory. Populate /var/lib/mina-indexer/blocks
# with precomputed blocks (e.g. an rsync from your block bucket) before starting.
#
# For the mesa-mut network, the genesis ledger (the hardfork state dump) is NOT
# embedded — supply it explicitly, e.g.:
#
#   MINA_INDEXER_ARGS=--network mesa \
#     --genesis-hash 3NLp6dKNhYtsqUj49QYV5GtDaeocSJBAa2y2ER2QQLqLukE3wuZT \
#     --genesis-ledger /var/lib/mina-indexer/mesa-genesis-ledger.json \
#     --blocks-dir /var/lib/mina-indexer/blocks \
#     --database-dir /var/lib/mina-indexer/db \
#     --web-hostname 0.0.0.0 --web-port 8080

MINA_INDEXER_ARGS=--blocks-dir /var/lib/mina-indexer/blocks --database-dir /var/lib/mina-indexer/db --web-hostname 0.0.0.0 --web-port 8080
